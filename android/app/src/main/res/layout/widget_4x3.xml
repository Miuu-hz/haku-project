<?xml version="1.0" encoding="utf-8"?>
<!-- 🎌 Haku Widget 4x3 - แสดงประวัติแชทล่าสุด + คำถาม -->
<LinearLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/widget_background"
    android:padding="12dp">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical">
        
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="箱 Haku AI"
            android:textColor="#9B7CB6"
            android:textSize="16sp"
            android:textStyle="bold"/>
        
        <View
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_weight="1"/>
        
        <ImageButton
            android:id="@+id/btn_new_entry"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/widget_button_circle"
            android:src="@drawable/ic_edit"
            android:contentDescription="เขียนบันทึก"/>
        
        <View
            android:layout_width="8dp"
            android:layout_height="0dp"/>
        
        <ImageButton
            android:id="@+id/btn_chat"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="@drawable/widget_button_circle"
            android:src="@drawable/ic_chat"
            android:contentDescription="คุยกับ Haku"/>
    </LinearLayout>

    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#2A2A3E"
        android:layout_marginVertical="8dp"/>

    <!-- 💬 ส่วนแสดงข้อความล่าสุด (สำหรับ 4x3) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:background="#1A1A2E"
        android:padding="8dp"
        android:layout_marginBottom="8dp">

        <!-- ข้อความ AI ล่าสุด -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="🤖 Haku"
            android:textSize="11sp"
            android:textColor="#9B7CB6"
            android:textStyle="bold"/>
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="สวัสดีค่ะ! วันนี้ฮาคุพร้อมช่วยเหลือแล้ว 🌸"
            android:textSize="12sp"
            android:textColor="#FFFFFF"
            android:maxLines="2"
            android:ellipsize="end"/>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="#2A2A3E"
            android:layout_marginVertical="6dp"/>

        <!-- ข้อความผู้ใช้ล่าสุด -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="👤 คุณ"
            android:textSize="11sp"
            android:textColor="#81C784"
            android:textStyle="bold"/>
        
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="วันนี้กินอะไรดี?"
            android:textSize="12sp"
            android:textColor="#CCCCCC"
            android:maxLines="1"
            android:ellipsize="end"/>
    </LinearLayout>

    <!-- คำถามสำเร็จรูป 2 แถว -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="2">

        <Button
            android:id="@+id/btn_q1"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:background="@drawable/widget_question_button"
            android:text="🍜 กินอะไร?"
            android:textSize="10sp"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btn_q2"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:background="@drawable/widget_question_button"
            android:text="😊 เป็นยังไง?"
            android:textSize="10sp"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btn_q3"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:background="@drawable/widget_question_button"
            android:text="📍 ไปไหน?"
            android:textSize="10sp"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btn_q4"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:background="@drawable/widget_question_button"
            android:text="🎵 อารมณ์?"
            android:textSize="10sp"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btn_q5"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:background="@drawable/widget_question_button"
            android:text="📅 เมื่อวาน?"
            android:textSize="10sp"
            android:textColor="#FFFFFF"/>

        <Button
            android:id="@+id/btn_q6"
            android:layout_width="0dp"
            android:layout_height="36dp"
            android:layout_columnWeight="1"
            android:layout_margin="2dp"
            android:background="@drawable/widget_question_button"
            android:text="💤 นอนดี?"
            android:textSize="10sp"
            android:textColor="#FFFFFF"/>
    </GridLayout>

</LinearLayout>
